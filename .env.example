# 网宿科技 edgecloud API 接入
# 用途：与自部署 vLLM 做 TTFT/decode 耗时对比（见 docs/benchmark-wangsu-vs-selfhosted.md）。
#
# 用法：复制本文件为 .env 并填入真实值。
#   cp .env.example .env
# .env 已被 .gitignore 忽略，不会被提交；切勿将真实 key 写入本文件。

# 网宿推理 API base URL（含租户路由 token，到产品路由名为止；
# measure_latency.py 会自动在末尾拼接 /chat/completions）
OPENAI_BASE_URL_WANGSU=https://aigateway.edgecloudapp.com/v1/<your-tenant-token>/lenovo_qwen

# 网宿 API Key（Bearer token）
OPENAI_API_KEY_WANGSU=<your-api-key>
